# Oracle Cloud Account Template
# ─────────────────────────────────────────────────────────────────────────
# 1. Copy this file: cp accounts/example.env accounts/<your-account>.env
# 2. Fill in the values below.
# 3. Use it: ./oracle-launch.sh <your-account>
#
# This file is gitignored; only example.env is committed.

# Display label (shown in logs + Telegram messages). Can be any UTF-8 string.
ACCOUNT_LABEL="🌍 MYACCT"

# ─── Identity ────────────────────────────────────────────────────────────
# OCID of the compartment to launch into. For Free Tier, this is usually the
# tenancy/root OCID. Get it from: OCI Console → Profile menu → Tenancy.
COMPARTMENT_OCID="ocid1.tenancy.oc1..xxxxxxxxxxxxxxxxxx"

# ─── Networking & Image ──────────────────────────────────────────────────
# Subnet OCID (NOT the VCN OCID). Get it from:
#   oci network subnet list --compartment-id <tenancy-ocid> --query 'data[*].{name:"display-name",id:id}'
SUBNET_OCID="ocid1.subnet.oc1.<region>.xxxxxxxxxxxxxxxxxx"

# Boot image OCID. Most popular choice: latest Canonical Ubuntu 22.04 aarch64.
# Get the latest:
#   oci compute image list --compartment-id <tenancy-ocid> \
#     --operating-system "Canonical Ubuntu" --operating-system-version "22.04" \
#     --shape "VM.Standard.A1.Flex" --sort-by TIMECREATED --sort-order DESC \
#     --limit 1 --query 'data[*].{name:"display-name",id:id}'
IMAGE_OCID="ocid1.image.oc1.<region>.xxxxxxxxxxxxxxxxxx"

# Availability Domains (space-separated). The script rotates across them on
# each retry attempt to maximize the chance of catching capacity. Get them:
#   oci iam availability-domain list --compartment-id <tenancy-ocid> --query 'data[*].name'
AD_NAMES="<prefix>:<REGION>-AD-1 <prefix>:<REGION>-AD-2 <prefix>:<REGION>-AD-3"

# ─── Instance Configuration ──────────────────────────────────────────────
INSTANCE_NAME="oracle-myacct-vm-arm-01"
INSTANCE_SHAPE="VM.Standard.A1.Flex"
INSTANCE_OCPUS="2"
INSTANCE_MEMORY_GB="12"

# ─── SSH Access ──────────────────────────────────────────────────────────
# Path to the public SSH key authorized to log into the instance.
SSH_PUBLIC_KEY_PATH="~/.ssh/id_rsa.pub"

# ─── OCI CLI Profile ─────────────────────────────────────────────────────
# Profile name from ~/.oci/config (one profile per Oracle account).
# If you only have one OCI account, this is usually "DEFAULT".
OCI_PROFILE="DEFAULT"
# OCI_CONFIG_FILE="~/.oci/config"  # uncomment to override default location

# ─── Retry Configuration ─────────────────────────────────────────────────
# How many AD attempts per script run. With 3 ADs, MAX_RETRIES=3 covers all.
# launchd/GitHub Actions will run the whole script again on the next interval.
MAX_RETRIES="3"
# Seconds to wait between attempts within a single run.
RETRY_INTERVAL="300"

# ─── Telegram Notifications (optional) ───────────────────────────────────
# Get a bot token: message @BotFather in Telegram, send /newbot.
# Get your chat ID: message your bot, then visit
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and look for "chat":{"id":...}.
# Leave both blank to disable Telegram notifications.
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""
